# Docker compose가 자동으로 읽는 환경변수 파일.
# 실제 사용 시에는 .env 로 복사하고 값을 채우세요.

# ── ASR 백엔드 ────────────────────────────────────────────
# - "dummy"  : 모델 로딩 스킵, 항상 같은 텍스트 반환 (UI 검증용)
# - 빈 값    : Whisper 사용 (TTT_MODEL_PATH 또는 openai/whisper-small)
TTT_ASR_BACKEND=dummy

# ── 학습된 모델 경로 ──────────────────────────────────────
# 호스트의 체크포인트 디렉토리. compose가 컨테이너의 /models 로 마운트한다.
# 모델 도착 전엔 비워두거나 ./.docker_empty_models 그대로.
TTT_MODEL_DIR=./.docker_empty_models

# 컨테이너 안에서 모델을 찾을 경로. 비워두면 openai/whisper-small 자동 폴백.
TTT_MODEL_PATH=

# ── Claude API (챗봇용) ───────────────────────────────────
ANTHROPIC_API_KEY=
