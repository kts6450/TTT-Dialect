# 로컬링크 환경 변수 — 이 파일을 복사해 .env 를 만들고 아래 값을 채우세요.
#   ./scripts/setup-env.sh
# 백엔드(main.py)와 docker compose 가 저장소 루트의 .env 를 읽습니다.
# .env 는 git 에 올라가지 않습니다.

# ═══════════════════════════════════════════════════════════
# API 키 (여기에 붙여넣기)
# ═══════════════════════════════════════════════════════════

# Claude — 음성 도우미(구매·판매), 판매 글 «설명 자동 작성»
# https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=

# OpenAI — 판매 글 «대표 사진 AI 생성»
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# 이미지 모델 (비우면 dall-e-2 → dall-e-3 순으로 시도)
# dall-e-3 만 400 나오면: OPENAI_IMAGE_MODEL=dall-e-2
OPENAI_IMAGE_MODEL=

# 프록시·Azure 등 쓸 때만 (공식 API면 비움)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ═══════════════════════════════════════════════════════════
# 음성 인식 (ASR) — 로컬 터미널에서 uvicorn 쓸 때
# ═══════════════════════════════════════════════════════════

# dummy = 모델 안 불러옴 (UI·API 빠른 확인, 키 없이 데모)
# 비우기 = Whisper (아래 TTT_MODEL_PATH 또는 openai/whisper-small)
TTT_ASR_BACKEND=dummy

# 로컬 체크포인트 폴더 또는 허브 id (터미널 실행 시)
# 예: TTT_MODEL_PATH=/Users/you/models/my-whisper-ko
# 예: TTT_MODEL_PATH=openai/whisper-small
TTT_MODEL_PATH=

# ═══════════════════════════════════════════════════════════
# Docker compose 만 쓸 때 (터미널만 쓰면 비워도 됨)
# ═══════════════════════════════════════════════════════════

TTT_MODEL_DIR=./.docker_empty_models

# ═══════════════════════════════════════════════════════════
# 선택
# ═══════════════════════════════════════════════════════════

# CORS_EXTRA_ORIGINS=http://192.168.0.10:5173
# DATABASE_URL=sqlite:///./webapp/backend/data/runtime/local_link.db

# 데모 시드 14건 다시 넣기 (기존 DB 목록 삭제 후 listings.seed.json 로드)
# LOCAL_LINK_RESEED=1

# ═══════════════════════════════════════════════════════════
# 회원 · 마스터 (운영자) 로그인
# ═══════════════════════════════════════════════════════════

# JWT 서명용 (운영 환경에서는 반드시 긴 랜덤 문자열로 변경)
# LOCAL_LINK_AUTH_SECRET=

# 마스터 계정 — DB에 없음, .env 로만 로그인
LOCAL_LINK_MASTER_EMAIL=master@local-link.kr
LOCAL_LINK_MASTER_PASSWORD=change-me-master
